# Base URL of the Tickiti instance (no trailing slash). The shim appends /api/v1/...
TICKITI_API_BASE=http://localhost:9191

# Sanctum personal-access token minted in Administration -> API keys.
# Its abilities (e.g. tickets:write, settings:read) are the real security
# boundary — the shim only relays calls, it does not widen them.
TICKITI_API_TOKEN=

# Optional request timeout in milliseconds (default 30000).
# TICKITI_API_TIMEOUT_MS=30000
